AIRFLOW_UID=501
AIRFLOW_GID=0

# Project root mounted inside Airflow containers
RAKUTEN_PROJECT_DIR=/project

# Project root as a real path on the HOST machine -- DockerOperator's
# ephemeral-trainer launch needs this (see rakuten_model_training.py's
# HOST_PROJECT_DIR comment); it's not derivable from inside a container.
# Update this if the repo is cloned somewhere else.
HOST_PROJECT_DIR=/Users/sumeyraozdemir/Documents/DS_Projects/liora_projects/mlops-rakuten-product-classification

# Path to the locally downloaded camembert-base model.
# This is the same directory as LOCAL_MODEL_PATH in
# models/textModeling/Model_T8_CamemBERT_FullFineTune_L128/config.py, whose
# own default already points here -- this var only needs to be set at all
# because rakuten_model_promotion.py reads it too, and .env's env_file
# loading means an unset/wrong value here overrides that correct default.
CAMEMBERT_BASE_DIR=/project/data/rakuten_streamlit_predictor/text_model/camembert_run4

# MLflow server lives in the root docker-compose stack (separate network).
# host.docker.internal resolves to the host machine on Docker Desktop (Mac/Windows).
MLFLOW_TRACKING_URI=http://host.docker.internal:5001

# Bounds retrain runs to 1 epoch on a real, meaningfully-sized (but not full
# 72k-row) sample -- fast enough to actually wait for (~7 min for text at
# ~2.46s/batch, measured), still a real architecture/model, not a 150-row
# toy. Use model=text for retrain requests -- image (ConvNeXt-Base) is
# ~19.4s/batch, ~8x slower per batch on top of a larger dataset.
MAX_EPOCHS_OVERRIDE=1
TRAIN_ROWS_OVERRIDE=100
VAL_ROWS_OVERRIDE=100
