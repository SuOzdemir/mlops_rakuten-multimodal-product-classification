# Copy this file to .env and replace the placeholders locally.
# Generate long, unique values (for example: openssl rand -hex 32).
# Keep passwords URL-safe because database passwords are used in connection URLs.
# Never commit .env or any real credentials.

# PostgreSQL (one admin plus separate passwords for each service database)
POSTGRES_ADMIN_PASSWORD=replace-with-a-long-random-value
MLFLOW_DB_PASSWORD=replace-with-a-different-long-random-value
AIRFLOW_DB_PASSWORD=replace-with-a-different-long-random-value
API_DB_PASSWORD=replace-with-a-different-long-random-value

# MinIO / S3-compatible object storage
MINIO_ROOT_USER=replace-with-a-non-default-user
MINIO_ROOT_PASSWORD=replace-with-a-long-random-value

# Grafana
GRAFANA_ADMIN_USER=replace-with-a-non-default-user
GRAFANA_ADMIN_PASSWORD=replace-with-a-long-random-value

# Airflow UI and REST API (the FastAPI service uses the same credentials)
AIRFLOW_API_USER=replace-with-a-non-default-user
AIRFLOW_API_PASSWORD=replace-with-a-long-random-value
AIRFLOW_ADMIN_EMAIL=replace-with-an-admin-email

# Initial application accounts. Used only when the API users table is empty.
API_ADMIN_PASSWORD=replace-with-a-long-random-value
API_VIEWER_PASSWORD=replace-with-a-different-long-random-value

# Airflow runtime paths/settings
AIRFLOW_UID=50000
AIRFLOW_GID=0
RAKUTEN_PROJECT_DIR=/project
HOST_PROJECT_DIR=/absolute/path/to/mlops-rakuten-product-classification
CAMEMBERT_BASE_DIR=/project/data/rakuten_streamlit_predictor/text_model/camembert_run4
MLFLOW_TRACKING_URI=http://host.docker.internal:5001
MAX_EPOCHS_OVERRIDE=1
TRAIN_ROWS_OVERRIDE=100
VAL_ROWS_OVERRIDE=100
DVC_ENDPOINT_URL=http://minio:9000
PROMOTION_MIN_F1_GAIN=0
# Set true for exactly one migration run only if an old champion has no metric tags.
PROMOTION_ALLOW_UNTAGGED_CHAMPION=false

# Optional monitoring notifications
GF_SMTP_ENABLED=true
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=your-email@gmail.com
GF_SMTP_PASSWORD=your-app-password
GF_SMTP_FROM_ADDRESS=your-email@gmail.com
GF_SMTP_FROM_NAME="Rakuten MLOps Alerts"
GF_SMTP_SKIP_VERIFY=false
ALERT_EMAIL_TO=recipient@example.com

# Optional Slack Incoming Webhook for prediction-drift alerts.
SLACK_WEBHOOK_URL=
